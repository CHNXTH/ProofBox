.home .pb-shell {
  display: flex;
  flex-direction: column;
}

.topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-dot {
  min-width: 44rpx;
  height: 20rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.46);
  border-radius: 999rpx;
  color: #40ff5e;
  text-align: center;
  font-size: 12rpx;
  line-height: 20rpx;
}

.selected-panel {
  display: grid;
  grid-template-columns: 1fr 76rpx;
  gap: 8rpx;
  align-items: center;
  margin-top: 6rpx;
  padding: 8rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.34);
  border-radius: 8rpx;
  background: rgba(64, 255, 94, 0.08);
}

.selected-copy {
  min-width: 0;
}

.selected-label {
  display: block;
  color: rgba(223, 255, 232, 0.58);
  font-size: 12rpx;
}

.selected-name {
  display: block;
  margin-top: 2rpx;
  color: #40ff5e;
  font-size: 20rpx;
  font-weight: 800;
}

.selected-subtitle {
  display: block;
  margin-top: 2rpx;
  color: rgba(223, 255, 232, 0.72);
  font-size: 13rpx;
}

.start-inline {
  height: 34rpx;
  border: 2rpx solid rgba(64, 255, 94, 0.76);
  border-radius: 8rpx;
  color: #050806;
  background: #40ff5e;
  font-size: 16rpx;
  font-weight: 800;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr 1fr;
  gap: 6rpx;
  margin-top: 6rpx;
}

.category-item {
  display: flex;
  min-height: 36rpx;
  flex-direction: column;
  justify-content: center;
  padding: 6rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.18);
  border-radius: 8rpx;
  background: rgba(223, 255, 232, 0.06);
  text-align: left;
}

.category-item.active {
  border-color: rgba(64, 255, 94, 0.78);
  background: rgba(64, 255, 94, 0.14);
}

.category-name {
  color: #ecfff1;
  font-size: 15rpx;
  font-weight: 700;
}

.category-subtitle {
  margin-top: 2rpx;
  color: rgba(223, 255, 232, 0.58);
  font-size: 10rpx;
  line-height: 1.1;
}

.command-row {
  display: none;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8rpx;
  margin-top: 6rpx;
  padding-top: 0;
}

.voice-hint {
  display: none;
}
