.home .pb-shell {
  display: flex;
  flex-direction: column;
}

.topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.status-dot {
  min-width: 76rpx;
  height: 34rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.46);
  border-radius: 999rpx;
  color: #40ff5e;
  text-align: center;
  font-size: 18rpx;
  line-height: 34rpx;
}

.selected-panel {
  display: grid;
  grid-template-columns: 1fr 132rpx;
  gap: 16rpx;
  align-items: center;
  margin-top: 24rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.34);
  border-radius: 14rpx;
  background: rgba(64, 255, 94, 0.08);
}

.selected-copy {
  min-width: 0;
}

.selected-label {
  display: block;
  color: rgba(223, 255, 232, 0.58);
  font-size: 18rpx;
}

.selected-name {
  display: block;
  margin-top: 6rpx;
  color: #40ff5e;
  font-size: 32rpx;
  font-weight: 800;
}

.selected-subtitle {
  display: block;
  margin-top: 6rpx;
  color: rgba(223, 255, 232, 0.72);
  font-size: 20rpx;
}

.start-inline {
  height: 70rpx;
  border: 2rpx solid rgba(64, 255, 94, 0.76);
  border-radius: 12rpx;
  color: #050806;
  background: #40ff5e;
  font-size: 24rpx;
  font-weight: 800;
}

.category-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
}

.category-item {
  display: flex;
  min-height: 96rpx;
  flex-direction: column;
  justify-content: center;
  padding: 14rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.18);
  border-radius: 14rpx;
  background: rgba(223, 255, 232, 0.06);
  text-align: left;
}

.category-item.active {
  border-color: rgba(64, 255, 94, 0.78);
  background: rgba(64, 255, 94, 0.14);
}

.category-name {
  color: #ecfff1;
  font-size: 24rpx;
  font-weight: 700;
}

.category-subtitle {
  margin-top: 6rpx;
  color: rgba(223, 255, 232, 0.58);
  font-size: 17rpx;
  line-height: 1.3;
}

.command-row {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 18rpx;
  padding-top: 0;
}

.voice-hint {
  margin-top: 10rpx;
  color: rgba(223, 255, 232, 0.55);
  font-size: 18rpx;
  text-align: center;
}
