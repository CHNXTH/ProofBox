<view class="pb-screen home">
  <view class="pb-shell">
    <view class="topline">
      <text class="pb-kicker">ProofBox 1.0</text>
      <text class="status-dot">AIUI</text>
    </view>

    <text class="pb-title">开箱有证</text>
    <text class="pb-subtitle">选择商品类型，眼镜会按步骤提示该拍的证据。</text>

    <view class="selected-panel">
      <view class="selected-copy">
        <text class="selected-label">当前类型</text>
        <text class="selected-name">{{selectedName}}</text>
        <text class="selected-subtitle">{{selectedSubtitle}}</text>
      </view>
      <button class="start-inline" bindtap="startFlow">开始</button>
    </view>

    <view class="category-grid">
      <button class="category-item {{phoneClass}}" data-id="phone" bindtap="selectCategory">
        <text class="category-name">手机</text>
        <text class="category-subtitle">IMEI/SN、激活状态、配件</text>
      </button>
      <button class="category-item {{computerClass}}" data-id="computer" bindtap="selectCategory">
        <text class="category-name">电脑</text>
        <text class="category-subtitle">机身 SN、开机、接口外观</text>
      </button>
      <button class="category-item {{collectibleClass}}" data-id="collectible" bindtap="selectCategory">
        <text class="category-name">潮玩</text>
        <text class="category-subtitle">盒损、内托、特典、缺件</text>
      </button>
      <button class="category-item {{bulkyClass}}" data-id="bulky" bindtap="selectCategory">
        <text class="category-name">大件</text>
        <text class="category-subtitle">外箱、缓冲、破损、配件</text>
      </button>
    </view>

    <view class="actions">
      <button class="pb-action" bindtap="startFlow">开始取证</button>
      <button class="pb-action secondary" bindtap="startQuickPhone">手机快开</button>
    </view>

    <view class="command-row">
      <text class="pb-chip">拍照</text>
      <text class="pb-chip">重拍</text>
      <text class="pb-chip">标记异常</text>
      <text class="pb-chip">生成总结</text>
    </view>

    <text class="voice-hint">{{wakeHint}}</text>
  </view>
</view>
