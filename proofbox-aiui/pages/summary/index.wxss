.summary-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
}

.ring {
  display: flex;
  width: 58rpx;
  height: 58rpx;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 3rpx solid rgba(64, 255, 94, 0.68);
  border-radius: 999rpx;
  background: rgba(64, 255, 94, 0.1);
}

.ring-number {
  color: #40ff5e;
  font-size: 18rpx;
  font-weight: 800;
}

.ring-label {
  margin-top: 1rpx;
  color: rgba(223, 255, 232, 0.58);
  font-size: 10rpx;
}

.metrics {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6rpx;
  margin-top: 6rpx;
}

.metric {
  padding: 6rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.16);
  border-radius: 8rpx;
  background: rgba(223, 255, 232, 0.06);
  text-align: center;
}

.metric-value {
  display: block;
  color: #ecfff1;
  font-size: 17rpx;
  font-weight: 800;
}

.metric-label {
  display: block;
  margin-top: 1rpx;
  color: rgba(223, 255, 232, 0.52);
  font-size: 10rpx;
}

.missing {
  display: grid;
  grid-template-columns: 64rpx 1fr;
  gap: 6rpx;
  margin-top: 5rpx;
  padding: 5rpx;
  border: 1rpx solid rgba(255, 220, 106, 0.3);
  border-radius: 8rpx;
  background: rgba(255, 220, 106, 0.06);
}

.missing-label {
  color: #ffdc6a;
  font-size: 11rpx;
}

.missing-value {
  color: rgba(223, 255, 232, 0.76);
  font-size: 11rpx;
}

.result-scroll {
  height: 46rpx;
  margin-top: 5rpx;
}

.result-block {
  padding: 6rpx;
  margin-bottom: 5rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.24);
  border-radius: 8rpx;
  background: rgba(64, 255, 94, 0.07);
}

.block-title {
  display: block;
  color: #40ff5e;
  font-size: 12rpx;
  font-weight: 700;
}

.block-text {
  display: block;
  margin-top: 3rpx;
  color: rgba(236, 255, 241, 0.84);
  font-size: 11rpx;
  line-height: 1.2;
}

.summary-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 6rpx;
  margin-top: 5rpx;
}
