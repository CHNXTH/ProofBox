.flow-shell {
  display: flex;
  flex-direction: column;
}

.hud-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.score {
  color: #40ff5e;
  font-size: 30rpx;
  font-weight: 800;
}

.progress-track {
  width: 100%;
  height: 8rpx;
  margin-top: 12rpx;
  border-radius: 999rpx;
  background: rgba(223, 255, 232, 0.12);
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #40ff5e;
}

.main-task {
  margin-top: 28rpx;
  padding: 22rpx;
  border: 2rpx solid rgba(64, 255, 94, 0.42);
  border-radius: 16rpx;
  background: rgba(64, 255, 94, 0.09);
}

.step-title {
  display: block;
  color: rgba(223, 255, 232, 0.72);
  font-size: 22rpx;
}

.instruction {
  display: block;
  margin-top: 8rpx;
  color: #ecfff1;
  font-size: 34rpx;
  font-weight: 800;
  line-height: 1.18;
}

.hint {
  display: block;
  margin-top: 10rpx;
  color: rgba(223, 255, 232, 0.64);
  font-size: 20rpx;
  line-height: 1.35;
}

.targets {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 16rpx;
}

.status-card {
  margin-top: 16rpx;
  padding: 16rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.16);
  border-radius: 14rpx;
  background: rgba(223, 255, 232, 0.06);
}

.status-card.abnormal {
  border-color: rgba(255, 220, 106, 0.58);
  background: rgba(255, 220, 106, 0.09);
}

.status-main {
  display: block;
  color: #40ff5e;
  font-size: 24rpx;
  font-weight: 700;
}

.status-sub {
  display: block;
  margin-top: 6rpx;
  color: rgba(223, 255, 232, 0.52);
  font-size: 18rpx;
}

.code-panel {
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 12rpx;
  margin-top: 16rpx;
}

.code-input {
  height: 72rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.34);
  border-radius: 12rpx;
  color: #ecfff1;
  background: rgba(0, 0, 0, 0.22);
  font-size: 20rpx;
}

.abnormal-panel {
  margin-top: 16rpx;
}

.panel-title {
  display: block;
  color: rgba(223, 255, 232, 0.58);
  font-size: 18rpx;
}

.abnormal-grid {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 8rpx;
  margin-top: 10rpx;
}

.abnormal-item {
  min-height: 46rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.18);
  border-radius: 10rpx;
  color: rgba(223, 255, 232, 0.7);
  background: rgba(223, 255, 232, 0.05);
  font-size: 18rpx;
}

.abnormal-item.active {
  border-color: rgba(255, 220, 106, 0.74);
  color: #ffdc6a;
  background: rgba(255, 220, 106, 0.09);
}

.abnormal-note {
  width: 100%;
  min-height: 76rpx;
  margin-top: 10rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(223, 255, 232, 0.16);
  border-radius: 12rpx;
  color: #ecfff1;
  background: rgba(0, 0, 0, 0.2);
  font-size: 18rpx;
}

.supplement {
  display: grid;
  grid-template-columns: 1fr 150rpx;
  gap: 12rpx;
  align-items: center;
  margin-top: 12rpx;
  padding: 12rpx;
  border: 1rpx solid rgba(255, 220, 106, 0.36);
  border-radius: 12rpx;
  background: rgba(255, 220, 106, 0.08);
  font-size: 18rpx;
}

.flow-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: auto;
  padding-top: 18rpx;
}

.bottom-row {
  display: grid;
  grid-template-columns: 90rpx 1fr 90rpx;
  gap: 12rpx;
  align-items: center;
  margin-top: 14rpx;
}

.text-button {
  color: rgba(223, 255, 232, 0.72);
  font-size: 18rpx;
}

.command-hint {
  color: rgba(223, 255, 232, 0.48);
  font-size: 16rpx;
  text-align: center;
}
