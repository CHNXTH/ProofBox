page {
  width: 100%;
  min-height: 100%;
  color: #dfffe8;
  background: #050806;
  font-family: system-ui, -apple-system, BlinkMacSystemFont, "PingFang SC", sans-serif;
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  background: transparent;
  color: inherit;
  line-height: 1;
}

.pb-screen {
  min-height: 100vh;
  padding: 28rpx;
  background: #050806;
}

.pb-shell {
  width: 100%;
  min-height: calc(100vh - 56rpx);
  border: 2rpx solid rgba(64, 255, 94, 0.42);
  border-radius: 20rpx;
  padding: 24rpx;
  background: rgba(4, 18, 9, 0.74);
}

.pb-kicker {
  color: rgba(158, 255, 180, 0.72);
  font-size: 22rpx;
}

.pb-title {
  margin-top: 10rpx;
  color: #ecfff1;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 1.2;
}

.pb-subtitle {
  margin-top: 10rpx;
  color: rgba(223, 255, 232, 0.72);
  font-size: 22rpx;
  line-height: 1.45;
}

.pb-primary {
  color: #40ff5e;
}

.pb-action {
  height: 72rpx;
  border: 2rpx solid rgba(64, 255, 94, 0.62);
  border-radius: 12rpx;
  color: #eaffee;
  background: rgba(64, 255, 94, 0.12);
  font-size: 24rpx;
  font-weight: 700;
}

.pb-action.secondary {
  border-color: rgba(223, 255, 232, 0.24);
  background: rgba(223, 255, 232, 0.08);
  color: rgba(223, 255, 232, 0.86);
}

.pb-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 42rpx;
  padding: 0 16rpx;
  border: 1rpx solid rgba(64, 255, 94, 0.34);
  border-radius: 999rpx;
  color: rgba(223, 255, 232, 0.86);
  background: rgba(64, 255, 94, 0.08);
  font-size: 20rpx;
}

.pb-muted {
  color: rgba(223, 255, 232, 0.58);
}

.pb-good {
  color: #40ff5e;
}

.pb-warn {
  color: #ffdc6a;
}

.pb-danger {
  color: #ff8f8f;
}
